# Copia a `.env` y ajusta según necesites. Todas las variables son opcionales;
# los valores mostrados aquí son los defaults.

# URL de conexión de SQLAlchemy (SQLite en archivo para que los datos sobrevivan
# a reinicios).
DATABASE_URL=sqlite:///./data/urlshortener.db

# URL base pública usada para construir el enlace `short` devuelto.
BASE_URL=http://localhost:8000

# Longitud de los códigos cortos auto-generados.
CODE_LENGTH=7

# Rate limit por IP (token bucket): tokens de capacidad, rellenados por segundo.
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_PER_SEC=10
